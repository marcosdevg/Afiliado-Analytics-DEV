{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/remotion/render-mp4/route.ts": {
      "includeFiles": "remotion/static-bundle/**",
      "maxDuration": 300
    },
    "src/app/api/mercadolivre/minha-lista-ofertas/refresh/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/gpl/cron-sync/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [

 
    { "path": "/api/cron/shopee-trends", "schedule": "0 * * * *" },
    { "path": "/api/cron/push?slug=bom-dia", "schedule": "0 11 * * *" },
    { "path": "/api/cron/push?slug=comissao-total", "schedule": "10 11 * * *" },
    { "path": "/api/cron/push?slug=relatorio-shopee", "schedule": "10 11 * * *" },
    { "path": "/api/cron/push?slug=tendencias-manha", "schedule": "0 13 * * *" },
    { "path": "/api/cron/push?slug=bom-almoco", "schedule": "10 15 * * *" },
    { "path": "/api/cron/push?slug=tendencias-tarde", "schedule": "0 18 * * *" },
    { "path": "/api/cron/push?slug=campanha-direta", "schedule": "0 21 * * *" }
  ],
  "rewrites": [
    {
      "source": "/:slug",
      "destination": "/api/r/:slug",
      "has": [
        {
          "type": "host",
          "value": "a.afiliadoanalytics.com.br"
        }
      ]
    }
  ]
}
